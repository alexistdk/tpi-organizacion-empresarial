<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_AsIs"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Claude Code" exporterVersion="1.0">
  <bpmn:collaboration id="Collaboration_AsIs">
    <bpmn:participant id="Participant_AsIs" name="Gestion de Vacaciones (AS-IS - Manual)" processRef="Process_AsIs" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AsIs" isExecutable="false">
    <bpmn:laneSet id="LaneSet_AsIs">
      <bpmn:lane id="Lane_Empleado" name="Empleado">
        <bpmn:flowNodeRef>StartEvent_AsIs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarSolicitud</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RecibirNotificacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_AsIs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_RRHHJefe" name="RRHH / Jefe">
        <bpmn:flowNodeRef>Task_RecibirPedido</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarSaldo</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ReenviarJefe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Aprobacion</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotificarEmpleado</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_AsIs" name="Empleado necesita vacaciones">
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_EnviarSolicitud" name="Enviar mail/planilla con la solicitud">
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecibirPedido" name="Recibir el pedido (mail/planilla)">
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RevisarSaldo" name="Revisar saldo de dias a mano (lento, sin trazabilidad)">
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_ReenviarJefe" name="Reenviar solicitud al jefe por mail">
      <bpmn:incoming>Flow_04</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Aprobacion" name="El jefe aprueba?">
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_Si</bpmn:outgoing>
      <bpmn:outgoing>Flow_No</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_NotificarEmpleado" name="Notificar resultado al empleado por mail">
      <bpmn:incoming>Flow_Si</bpmn:incoming>
      <bpmn:incoming>Flow_No</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecibirNotificacion" name="Recibir notificacion del resultado">
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="EndEvent_AsIs" name="Solicitud resuelta">
      <bpmn:incoming>Flow_07</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_AsIs" targetRef="Task_EnviarSolicitud" />
    <bpmn:sequenceFlow id="Flow_02" name="Mail / planilla" sourceRef="Task_EnviarSolicitud" targetRef="Task_RecibirPedido" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_RecibirPedido" targetRef="Task_RevisarSaldo" />
    <bpmn:sequenceFlow id="Flow_04" sourceRef="Task_RevisarSaldo" targetRef="Task_ReenviarJefe" />
    <bpmn:sequenceFlow id="Flow_05" sourceRef="Task_ReenviarJefe" targetRef="Gateway_Aprobacion" />
    <bpmn:sequenceFlow id="Flow_Si" name="Si (aprueba)" sourceRef="Gateway_Aprobacion" targetRef="Task_NotificarEmpleado" />
    <bpmn:sequenceFlow id="Flow_No" name="No (rechaza)" sourceRef="Gateway_Aprobacion" targetRef="Task_NotificarEmpleado" />
    <bpmn:sequenceFlow id="Flow_06" name="Mail con resultado" sourceRef="Task_NotificarEmpleado" targetRef="Task_RecibirNotificacion" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_RecibirNotificacion" targetRef="EndEvent_AsIs" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AsIs">
    <bpmndi:BPMNPlane id="BPMNPlane_AsIs" bpmnElement="Collaboration_AsIs">
      <bpmndi:BPMNShape id="Participant_AsIs_di" bpmnElement="Participant_AsIs" isHorizontal="true">
        <dc:Bounds x="120" y="80" width="1380" height="360" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Empleado_di" bpmnElement="Lane_Empleado" isHorizontal="true">
        <dc:Bounds x="150" y="80" width="1350" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_RRHHJefe_di" bpmnElement="Lane_RRHHJefe" isHorizontal="true">
        <dc:Bounds x="150" y="260" width="1350" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_AsIs_di" bpmnElement="StartEvent_AsIs">
        <dc:Bounds x="212" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="190" y="185" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EnviarSolicitud_di" bpmnElement="Task_EnviarSolicitud">
        <dc:Bounds x="310" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecibirPedido_di" bpmnElement="Task_RecibirPedido">
        <dc:Bounds x="490" y="300" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RevisarSaldo_di" bpmnElement="Task_RevisarSaldo">
        <dc:Bounds x="660" y="300" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReenviarJefe_di" bpmnElement="Task_ReenviarJefe">
        <dc:Bounds x="830" y="300" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Aprobacion_di" bpmnElement="Gateway_Aprobacion" isMarkerVisible="true">
        <dc:Bounds x="1005" y="315" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="990" y="372" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotificarEmpleado_di" bpmnElement="Task_NotificarEmpleado">
        <dc:Bounds x="1130" y="300" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecibirNotificacion_di" bpmnElement="Task_RecibirNotificacion">
        <dc:Bounds x="1130" y="120" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_AsIs_di" bpmnElement="EndEvent_AsIs">
        <dc:Bounds x="1342" y="142" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1320" y="185" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_01_di" bpmnElement="Flow_01">
        <di:waypoint x="248" y="160" />
        <di:waypoint x="310" y="160" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_02_di" bpmnElement="Flow_02">
        <di:waypoint x="370" y="200" />
        <di:waypoint x="370" y="340" />
        <di:waypoint x="490" y="340" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="375" y="263" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_03_di" bpmnElement="Flow_03">
        <di:waypoint x="610" y="340" />
        <di:waypoint x="660" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_04_di" bpmnElement="Flow_04">
        <di:waypoint x="780" y="340" />
        <di:waypoint x="830" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_05_di" bpmnElement="Flow_05">
        <di:waypoint x="950" y="340" />
        <di:waypoint x="1005" y="340" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Si_di" bpmnElement="Flow_Si">
        <di:waypoint x="1055" y="340" />
        <di:waypoint x="1130" y="340" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1065" y="322" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_No_di" bpmnElement="Flow_No">
        <di:waypoint x="1030" y="365" />
        <di:waypoint x="1030" y="410" />
        <di:waypoint x="1190" y="410" />
        <di:waypoint x="1190" y="380" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1040" y="413" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_06_di" bpmnElement="Flow_06">
        <di:waypoint x="1190" y="300" />
        <di:waypoint x="1190" y="200" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1195" y="240" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_07_di" bpmnElement="Flow_07">
        <di:waypoint x="1250" y="160" />
        <di:waypoint x="1342" y="160" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
